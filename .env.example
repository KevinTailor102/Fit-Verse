# ============================================================
#  FitVerse — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# Flask
SECRET_KEY=your-super-secret-flask-key-change-this
FLASK_ENV=development
FLASK_DEBUG=1

# Database
DATABASE_URL=sqlite:///fitverse.db

WATSONX_API_KEY=your-ibm-cloud-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# IBM Granite model ID (default: granite-13b-chat-v2)
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# Optional: IBM Cloud Code Engine deployment
IBM_REGION=us-south
IBM_RESOURCE_GROUP=Default
